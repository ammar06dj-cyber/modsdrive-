# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ADMIN_PASSWORD: Password required to access the Administrative Panel.
# This variable is server-side only and is NEVER exposed to the client/browser bundle.
# NEVER create a "VITE_ADMIN_PASSWORD" variable or use the "VITE_" prefix for this secret, as that exposes it to the client-side bundle.
ADMIN_PASSWORD=your_password_here

# SUPABASE_SERVICE_ROLE_KEY: The secret Supabase service role API key (strictly server-side only).
# This key is strictly server-side only and has full bypass access on RLS rules to execute administrative operations.
# NEVER expose this key to the frontend or assign it with a "VITE_" prefix.
# NOTE: VITE_SUPABASE_ANON_KEY is strictly for client/anon public reads, NOT for administrative/server operations.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ALLOW_IFRAME_PREVIEW: Toggle to allow/deny staging/preview iframe embedding.
# Set to 'true' in development or sandbox/staging to allow AI Studio framing.
# MUST be false or unset in Production to guarantee strict clickjacking prevention.
ALLOW_IFRAME_PREVIEW=false

# SUPABASE_URL: Optional server-side Supabase URL override (falls back to VITE_SUPABASE_URL if unset).
# This is used for server client initialization.
SUPABASE_URL=your_supabase_url_here

